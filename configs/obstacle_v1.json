                {
                    "position_tolerance": 0.011
                },
                {
                    "position_tolerance": 0.01
                }
            ]
        }
    },
    "behaviour-clone": {
        "lr": 0.001,
        "batch_size": 128,
        "weight_decay": 1e-05,
        "epochs": 100
    }
