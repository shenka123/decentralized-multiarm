{
    "description": "Take position of 2 nearest sphere obstacles into arm state.",
    "description2": "v2 is trained incrementally for number of arms.",
    "training": {
        "k_nearest_obstacles": 2,
        "observations": {
            "items": [
                {
                    "name": "joint_values",
                    "dimensions": 6,
                    "history": 1
                },
                {
                    "name": "end_effector_pose",
                    "dimensions": 7,
                    "history": 1
                },
                {
                    "name": "target_pose",
                    "dimensions": 7,
                    "history": 1
                },
                {
                    "name": "link_positions",
                    "dimensions": 30,
                    "history": 1
                },
                {
                    "name": "pose",
                    "dimensions": 7,
                    "history": 0
                },
                {
                    "name": "nearest_obstacles",
                    "dimensions": 6,
                    "history": 0
                }
            ]
        },
        "action_variance": {
            "max": 0.1,
            "min": 1e-08,
            "log": true
        },
        "centralized_policy": false,
        "centralized_critic": false,
        "algo": "sac",
        "hyperparameters": {
            "pi_lr": 0.0005,
            "q_lr": 0.001,
            "discount": 0.99,
            "tau": 0.001,
            "alpha": 0.001,
            "batch_size": 4096,
            "warmup_timesteps": 20000.0,
            "memory_cluster_capacity": 50000.0,
            "num_updates_per_train": 10,
            "minimum_replay_buffer_freshness": 0.7,
            "action_scaling": 1
        },
        "network": {
            "critic": {
                "modules": [
                    "lstm",
                    "mlp"
                ],
                "mlp_layers": [
                    128,
                    64
                ],
                "lstm_hidden_size": 256,
                "lstm_num_layers": 1,
                "lstm_bidirectional": false,
                "initial_hidden_state": "zero"
            },
            "actor": {
                "modules": [
                    "lstm",
                    "mlp"
                ],
                "mlp_layers": [
                    128,
                    64
                ],
                "lstm_hidden_size": 256,
                "lstm_num_layers": 1,
                "lstm_bidirectional": false,
                "initial_hidden_state": "zero"
            }
        },
        "update_interval": 16000,
        "save_interval": 1,
        "num_processes": 10
    },
    "environment": {
        "action_type": "delta",
        "min_ur5s_count": 1,
        "max_ur5s_count": 4,
        "obstacles": {
            "s1": {
                "type": "Sphere",
                "radius": 0.1
            },
            "s2": {
                "type": "Sphere",
                "radius": 0.1
            },
            "s3": {
                "type": "Sphere",
                "radius": 0.1
            },
            "s4": {
                "type": "Sphere",
                "radius": 0.1
            },
            "s5": {
                "type": "Sphere",
                "radius": 0.1
            }
        },
        "task": {
            "generation_method": "random",
            "type": "static",
            "difficulty": {
                "min_distance_between_bases": 0.3,
                "max_distance_between_bases": 1.0
            }
        },
        "expert": {
            "expert_on_fail": true,
            "waypoint_conversion_mode": "tolerance",
            "threshold_config ": {
                "threshold": 0.1
            },
            "tolerance_config": {
                "max_magnitude": 0.5,
                "tolerance": 0.1,
                "threshold": 0.01
            }
        },
        "ur5s_position_picker": "evenly_spaced",
        "retry_on_fail": false,
        "prioritized_task_loader": false,
        "workspace_radius": 0.85,
        "early_stop": {
            "threshold": 0,
            "steps": 10
        },
        "reward": {
            "collision_penalty": -0.05,
            "individually_reach_target": 0.01,
            "cooperative_individual_reach_target": false,
            "collectively_reach_target": 1.0,
            "survival_penalty": 0,
            "delta": {
                "position": 0.1,
                "orientation": 0,
                "activation_radius": 0.2
            },
            "supervision_penalty": 0,
            "proximity_penalty": {
                "max_distance": 1.0,
                "penalty": 0
            }
        },
        "terminate_on_collision": true,
        "terminate_on_collectively_reach_target": true,
        "episode_length": 500,
        "action_interval": 0.05,
        "collision_distance": 0.0,
        "stop_ur5_after_reach": false,
        "ur5_speed": 0.02,
        "position_tolerance": 0.04,
        "orientation_tolerance": 0.1,
        "curriculum": {
            "graduation_threshold": 0.7,
            "levels": [
                {
                    "position_tolerance": 0.5,
